<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <!-- 
    Purpose: 统一的交配与色情动作(Lovin' & Erotic Jobs)管理补丁。
    所有的性爱、发泄、色情行为都必须在此处打上对应的 ModExtension 标签。
    通过这种机制，C# 代码不需要硬编码任何 JobDef，极大地提高了扩展性和模块解耦。
    -->
    <Operation Class="PatchOperationSequence">
        <success>Always</success>
        <operations>
            
            <!-- ========================================================================= -->
            <!-- 1. Mating Jobs (交配动作) -->
            <!-- 带有此标签的 Job，会触发：AV摄影记录、主模组交配次数统计、RJW需求恢复、RJW交配结算 -->
            <!-- ========================================================================= -->
            
            <!-- 原版：双人床爱爱 -->
            <li Class="PatchOperationAddModExtension">
                <xpath>Defs/JobDef[defName="Lovin"]</xpath>
                <value><li Class="RavenRace.Features.Reproduction.DefModExtension_LovinJob" /></value>
            </li>

            <!-- 渡鸦族：强制求爱 -->
            <li Class="PatchOperationAddModExtension">
                <xpath>Defs/JobDef[defName="Raven_Job_ForceLovin"]</xpath>
                <value><li Class="RavenRace.Features.Reproduction.DefModExtension_LovinJob" /></value>
            </li>

            <!-- 机械天使的两种榨汁行为 -->
            <li Class="PatchOperationAddModExtension">
                <xpath>Defs/JobDef[
                    defName="Raven_Job_AegisLustCharge" or 
                    defName="Raven_Job_AegisRampageCharge"
                ]</xpath>
                <value><li Class="RavenRace.Features.Reproduction.DefModExtension_LovinJob" /></value>
            </li>

            <!-- 渡鸦族：扶桑繁衍请求 (安全判定，防止重复添加) -->
            <li Class="PatchOperationConditional">
                <xpath>Defs/JobDef[defName="Raven_Job_ReproductionRequestLovin" and not(modExtensions/li[@Class="RavenRace.Features.Reproduction.DefModExtension_LovinJob"])]</xpath>
                <match Class="PatchOperationAddModExtension">
                    <xpath>Defs/JobDef[defName="Raven_Job_ReproductionRequestLovin"]</xpath>
                    <value><li Class="RavenRace.Features.Reproduction.DefModExtension_LovinJob" /></value>
                </match>
            </li>

            <!-- 特殊：迪克雨 欲望难忍 (涉及双人强行侵犯发泄，划分为交配) -->
            <li Class="PatchOperationAddModExtension">
                <xpath>Defs/JobDef[defName="DickRain_YuwangNanRen"]</xpath>
                <value><li Class="RavenRace.Features.Reproduction.DefModExtension_LovinJob" /></value>
            </li>


            <!-- ========================================================================= -->
            <!-- 2. Erotic Jobs (色情/发泄动作) -->
            <!-- 带有此标签的 Job，仅触发：RJW个人性需求恢复，不统计为交配次数。 -->
            <!-- ========================================================================= -->
            
            <li Class="PatchOperationAddModExtension">
                <xpath>Defs/JobDef[
                    defName="Raven_Job_HypnoticSelfPleasure" or 
                    defName="Raven_Job_TakeSlimeBath" or 
                    defName="Raven_WatchAV" or 
                    defName="Raven_Job_MasturbateWithCup" or 
                    defName="Raven_Job_DimensionalClimax" or 
                    defName="Raven_Job_EnterConfessionBooth"
                ]</xpath>
                <value>
                    <!-- 引用我们新建的核心色情标记类 -->
                    <li Class="RavenRace.Core.Sexuality.DefModExtension_EroticJob" />
                </value>
            </li>

            <!-- 
                未来添加说明：
                如果你新建了一个 Job 比如 "Raven_PlayToy"，只需在这里加入 defName="Raven_PlayToy" 即可，
                所有底层的状态恢复、RJW 联动都会自动生效。
            -->

        </operations>
    </Operation>
</Patch>