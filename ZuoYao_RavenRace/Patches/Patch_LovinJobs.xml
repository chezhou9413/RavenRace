<?xml version="1.0" encoding="utf-8"?>
<Patch>
  <!-- 
    核心泛用扩展！
    只要你以后想让任何一个原版或Mod的Job增加角色的交配次数，
    只需要用这种方式给它的 <modExtensions> 里塞入 DefModExtension_LovinJob 即可！
  -->
  
  <!-- 1. 注入到原版双人床爱爱 -->
  <Operation Class="PatchOperationAddModExtension">
    <xpath>Defs/JobDef[defName="Lovin"]</xpath>
    <value>
      <li Class="RavenRace.Features.Reproduction.DefModExtension_LovinJob" />
    </value>
  </Operation>

  <!-- 2. 注入到我们的强制求爱 -->
  <Operation Class="PatchOperationAddModExtension">
    <xpath>Defs/JobDef[defName="Raven_Job_ForceLovin"]</xpath>
    <value>
      <li Class="RavenRace.Features.Reproduction.DefModExtension_LovinJob" />
    </value>
  </Operation>
</Patch>