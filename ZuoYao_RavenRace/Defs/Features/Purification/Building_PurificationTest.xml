<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- 1. 仪式建筑定义 -->
  <ThingDef ParentName="BuildingBase">
    <defName>Raven_Building_PurificationTest</defName>
    <label>纯化仪式基座 (测试)</label>
    <description>一座临时搭建的灵能节点，用于测试金乌血脉的跨阶纯化仪式。\n\n当渡鸦族体内的金乌浓度达到当前阶段的极限时，可以通过与此基座共鸣来尝试打破桎梏。仪式具有一定失败率，但不会造成生命危险。</description>
    <!-- 使用我们专用的建筑逻辑类 -->
    <thingClass>RavenRace.Features.Purification.Building_PurificationAltar</thingClass>
    <graphicData>
      <!-- 借用注入仪贴图占位 -->
      <texPath>Buildings/SoulAltar/RavenInjector</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.5, 1.5)</drawSize>
    </graphicData>
    <size>(1,1)</size>
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <pathCost>50</pathCost>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <WorkToBuild>500</WorkToBuild>
      <Flammability>0</Flammability>
    </statBases>
    <costList>
      <WoodLog>10</WoodLog>
    </costList>
    <!-- 交互点必须设置，否则小人走不过去 -->
    <interactionCellOffset>(0,0,-1)</interactionCellOffset>
    <hasInteractionCell>true</hasInteractionCell>
    <designationCategory>Raven_Category</designationCategory>
  </ThingDef>

  <!-- 2. 工作定义 -->
  <JobDef>
    <defName>Raven_Job_PurificationRitual</defName>
    <driverClass>RavenRace.Features.Purification.JobDriver_PurificationRitual</driverClass>
    <reportString>正在经受烈火的试炼 (纯化仪式)。</reportString>
    <allowOpportunisticPrefix>false</allowOpportunisticPrefix>
    <casualInterruptible>false</casualInterruptible>
  </JobDef>

</Defs>