<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="BaseMeleeWeapon_Blunt">
    <!-- 内部定义名 -->
    <defName>dickcoller</defName>
    <!-- 游戏内名称 -->
    <label>爻五宝</label>
    <!-- 游戏内描述 (当前为原版木棒的描述) -->
    <description>五金之英，太阳之精。一曰湛卢，二曰纯钧，三曰胜邪，四曰鱼肠，五曰巨阙。</description>
    <allowedArchonexusCount>1</allowedArchonexusCount>
    <altitudeLayer>Item</altitudeLayer>
    <alwaysHaulable>true</alwaysHaulable>
    <burnableByRecipe>true</burnableByRecipe>
    <category>Item</category>
    
    <!-- 武器组件 -->
    <comps>
      <li Class="RavenRace.Features.dick.CompProperties_OrbitSwords">
        <!-- 指定当执行“归元入体”时，为持有者添加哪个Hediff -->
        <hideHediff>Raven_Hediff_GuiYuanRuTi</hideHediff>
      </li>
    </comps>
    
    <!-- 制作所需材料数量 -->
    <costStuffCount>40</costStuffCount>
    <drawerType>MapMeshOnly</drawerType>
    <drawGUIOverlay>true</drawGUIOverlay>
    <equipmentType>Primary</equipmentType>
    <equippedAngleOffset>-65</equippedAngleOffset>
    
    <!-- 贴图数据 -->
    <graphicData>
      <onGroundRandomRotateAngle>35</onGroundRandomRotateAngle>
      <texPath>Things/Item/Equipment/WeaponMelee/Club</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    
    <inspectorTabs>
      <li>ITab_Art</li>
    </inspectorTabs>
    
    <pathCost>14</pathCost>
    
    <!-- 制作配方 -->
    <recipeMaker>
      <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
      <workSkill>Crafting</workSkill>
      <effectWorking>Smith</effectWorking>
      <soundWorking>Recipe_Smith</soundWorking>
      <recipeUsers>
        <li>ElectricSmithy</li>
        <li>FueledSmithy</li>
        <li>CraftingSpot</li>
      </recipeUsers>
      <unfinishedThingDef>UnfinishedWeapon</unfinishedThingDef>
      <defaultIngredientFilter>
        <categories>
          <li>Root</li>
        </categories>
        <disallowedThingDefs>
          <li>Silver</li>
          <li>Gold</li>
        </disallowedThingDefs>
      </defaultIngredientFilter>
      <displayPriority>300</displayPriority>
    </recipeMaker>
    
    <relicChance>1</relicChance>
    <rotatable>false</rotatable>
    <selectable>true</selectable>
    <smeltable>true</smeltable>
    
    <!-- 基础属性 -->
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <Flammability>1</Flammability>
      <DeteriorationRate>2</DeteriorationRate>
      <Beauty>-3</Beauty>
      <SellPriceFactor>0.2</SellPriceFactor>
      <WorkToMake>1200</WorkToMake>
      <Mass>2</Mass>
    </statBases>
    
    <!-- 可用材料 -->
    <stuffCategories>
      <li>Metallic</li>
      <li>Woody</li>
      <li>Stony</li>
    </stuffCategories>
    
    <techLevel>Neolithic</techLevel>
    
    <tradeability>None</tradeability>    <!-- 核心修改: 禁止此物品被交易或在NPC身上自然生成 -->
    
    <thingClass>ThingWithComps</thingClass>
    <tickerType>Normal</tickerType>
    
    <!-- 攻击方式 -->
    <tools>
      <li>
        <label>handle</label>
        <capacities>
          <li>Poke</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
      <li>
        <label>head</label>
        <labelUsedInLogging>false</labelUsedInLogging>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>14</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
    
    <weaponClasses>
      <li>Melee</li>
      <li>MeleeBlunt</li>
      <li>Neolithic</li>
    </weaponClasses>
    
    <!-- 核心修改: 移除了weaponTags，这样NPC和派系就不会自动生成并携带此武器了 -->

  </ThingDef>
</Defs>