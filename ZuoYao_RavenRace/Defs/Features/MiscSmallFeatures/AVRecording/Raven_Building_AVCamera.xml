<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- AV 摄影机建筑 -->
  <ThingDef ParentName="BuildingBase">
    <defName>Raven_Building_AVCamera</defName>
    <label>全息摄影机</label>
    <description>一台配备了全息捕捉与隐蔽记录功能的先进摄影设备。\n\n只要提供电力，它就会静默地监控其视野范围内的一切。当它识别到范围内有生物在进行“繁衍活动”并结束时，会自动将过程提取并压缩成极其珍贵的加密影像弹出。\n\n如果将它放在房间，该房间会被判定为“AV摄影房”，它将能产出价值连城的典藏版影像！</description>
    
    <!-- 绑定我们的核心逻辑类 -->
    <thingClass>RavenRace.Features.MiscSmallFeatures.AVRecording.Building_AVCamera</thingClass>
    <category>Building</category>
    
    <graphicData>
      <!-- 指向独立的贴图路径 -->
      <texPath>Buildings/MiscSmallFeatures/AVCamera/AVCamera</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(1,1)</drawSize>
      <shadowData>
        <volume>(0.3, 0.5, 0.3)</volume>
      </shadowData>
    </graphicData>
    
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <fillPercent>0.3</fillPercent>
    <size>(1,1)</size>
    <rotatable>true</rotatable>
    
    <!-- 核心：这个字段会在玩家选中建筑时，在地上画出一个白色的圈，表示拍摄范围 -->
    <specialDisplayRadius>12.9</specialDisplayRadius>

    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <WorkToBuild>1500</WorkToBuild>
      <Flammability>0.5</Flammability>
      <Beauty>2</Beauty>
    </statBases>

    <costList>
      <Steel>80</Steel>
      <ComponentIndustrial>5</ComponentIndustrial>
    </costList>

    <comps>
      <li Class="CompProperties_Power">
        <compClass>CompPowerTrader</compClass>
        <basePowerConsumption>150</basePowerConsumption>
        <shortCircuitInRain>true</shortCircuitInRain>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_Breakdownable"/>
    </comps>

    <designationCategory>Raven_Category</designationCategory>
    <researchPrerequisites>
      <li>RavenResearch_Reproduction</li>
    </researchPrerequisites>
    <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
  </ThingDef>
</Defs>