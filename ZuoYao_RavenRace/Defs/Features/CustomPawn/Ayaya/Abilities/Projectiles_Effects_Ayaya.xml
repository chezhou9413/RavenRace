<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- 飞行器 -->
  <ThingDef ParentName="PawnFlyerBase">
    <defName>Raven_PawnFlyer_AyayaDash</defName>
    <thingClass>RavenRace.Features.CustomPawn.Ayaya.PawnFlyer_AyayaDash</thingClass>
    <pawnFlyer>
      <flightDurationMin>0.1</flightDurationMin>
      <flightSpeed>30</flightSpeed>
      <heightFactor>0.2</heightFactor>
    </pawnFlyer>
  </ThingDef>

  <ThingDef ParentName="PawnFlyerBase">
    <defName>Raven_PawnFlyer_Knockback</defName>
    <thingClass>RavenRace.Features.CustomPawn.Ayaya.PawnFlyer_Knockback</thingClass>
    <pawnFlyer>
      <flightDurationMin>0.4</flightDurationMin>
      <flightSpeed>15</flightSpeed>
      <heightFactor>1.2</heightFactor>
    </pawnFlyer>
  </ThingDef>

<!-- 东方弹幕投射物 -->
<ThingDef ParentName="BaseBullet">
  <defName>Raven_Projectile_WindBlade</defName>
  <label>风刃</label>
  <thingClass>RavenRace.Features.CustomPawn.Ayaya.Projectile_TouhouDanmaku</thingClass>

  <graphicData>
    <texPath>Things/Projectile/WindBlade</texPath>
    <graphicClass>Graphic_Single</graphicClass>
    <shaderType>Transparent</shaderType>
  </graphicData>
  
  <!-- 关键：在<projectile>标签上指定我们自定义的Class -->
  <projectile Class="RavenRace.Features.CustomPawn.Ayaya.ProjectileProperties_TouhouDanmaku">
    <damageDef>Blunt</damageDef>
    <damageAmountBase>25</damageAmountBase>
    <armorPenetrationBase>0.4</armorPenetrationBase>
    <stoppingPower>0.5</stoppingPower>
    <speed>10</speed>
    <collisionRadius>1.5</collisionRadius>    <!-- 这里就是我们的新属性！1.5的半径会形成一个直径约3格的圆形碰撞区域 -->
  </projectile>

</ThingDef>



  <!-- 特效 (EffecterDef) -->
  <EffecterDef>
    <defName>Raven_Effecter_TenguGale</defName>
    <children>
      <li>
        <!-- [核心修复] 使用具体子类 SubEffecter_SprayerTriggered 替代抽象类 -->
        <subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
        <fleckDef>Smoke</fleckDef>
        <burstCount>5~8</burstCount>
        <scale>1.5~2.5</scale>
        <speed>2~4</speed>
        <airTime>0.5~1.0</airTime>
        <positionRadius>0.5</positionRadius>
      </li>
      <li>
        <!-- [核心修复] 使用具体子类 SubEffecter_SprayerTriggered 替代抽象类 -->
        <subEffecterClass>SubEffecter_SprayerTriggered</subEffecterClass>
        <fleckDef>AirPuff</fleckDef>
        <burstCount>3~5</burstCount>
        <scale>1.0~1.5</scale>
        <speed>0.5~1.0</speed>
        <positionRadius>1.0</positionRadius>
      </li>
    </children>
  </EffecterDef>

</Defs>