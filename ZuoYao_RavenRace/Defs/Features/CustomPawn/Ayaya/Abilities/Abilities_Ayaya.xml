<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- 技能：无双风神 -->
  <AbilityDef>
    <defName>Raven_Ability_Ayaya_MusouFuujin</defName>
    <label>无双风神</label>
    <description>"疾风啊，撕裂一切吧！"\n\n射命丸文将自身化作一道无法捕捉的疾风残影，以神速穿过战场。任何处于她冲刺路径上的敌人都将受到肉眼无法看清的风刃切割，冲刺终点区域的敌人还将遭受东方弹幕的密集打击。\n\n效果：超远距离冲刺 + 路径穿透切割伤害 + 落点范围弹幕覆盖。</description>
    <iconPath>Races/Raven/Special/Ayaya/Abilities/MusouFuujin</iconPath>
    <cooldownTicksRange>400</cooldownTicksRange>
    <targetRequired>true</targetRequired>
    <verbProperties>
      <!-- 使用自定义 Verb，继承自 Verb_CastAbilityJump -->
      <verbClass>RavenRace.Features.CustomPawn.Ayaya.Verb_AyayaMusouFuujin</verbClass>
      <label>冲刺</label>
      <violent>true</violent>
      <forceNormalTimeSpeed>false</forceNormalTimeSpeed>
      <range>34.9</range>
      <requireLineOfSight>true</requireLineOfSight>
      <soundCast>Psycast_Skip_Exit</soundCast>
    </verbProperties>
    <!-- 飞行器由 Verb 内的 JumpFlyerDef 属性直接指定，不需要额外的 Comp -->
  </AbilityDef>

  <!-- 技能：天狗颪 -->
  <AbilityDef>
    <defName>Raven_Ability_Ayaya_TenguOtoshi</defName>
    <label>天狗颪</label>
    <description>"这阵风，可是能把房子都吹跑的哦。"\n\n射命丸文猛力挥动团扇，以自身为中心召唤出一股强烈的旋转下沉气流（颪）。这股怪风将范围内的所有敌人强行卷起并重重摔在地上，造成钝器伤害与眩晕。\n\n效果：以自身为中心大范围吹飞（12格）+ 落地钝器伤害 + 眩晕。</description>
    <iconPath>Races/Raven/Special/Ayaya/Abilities/TenguOtoshi</iconPath>
    <cooldownTicksRange>900</cooldownTicksRange>
    <!-- targetRequired=false：以自身为中心触发，无需选择目标 -->
    <targetRequired>false</targetRequired>
    <verbProperties>
      <verbClass>Verb_CastAbility</verbClass>
      <!-- range=0.1 确保技能可以立即对自身触发，不需要选择外部目标 -->
      <range>0.1</range>
      <warmupTime>0.8</warmupTime>
      <targetParams>
        <!-- 允许以自身为目标，配合 targetRequired=false 实现自触发 -->
        <canTargetSelf>true</canTargetSelf>
        <canTargetPawns>true</canTargetPawns>
        <canTargetBuildings>false</canTargetBuildings>
        <canTargetLocations>false</canTargetLocations>
      </targetParams>
      <soundCast>ThrowGrenade</soundCast>
    </verbProperties>
    <comps>
      <li Class="RavenRace.Features.CustomPawn.Ayaya.CompProperties_AbilityTenguGale">
        <!-- 以施法者为中心的吹飞半径（格） -->
        <blastRadius>12</blastRadius>
        <!-- 击退飞行距离（格） -->
        <knockbackDistance>14</knockbackDistance>
        <!-- 体型上限（超过 3.0 的生物无法被吹飞） -->
        <maxBodySize>3.0</maxBodySize>
        <flyerDef>Raven_PawnFlyer_Knockback</flyerDef>
      </li>
      <li Class="CompProperties_AbilityEffecterOnTarget">
        <effecterDef>Raven_Effecter_TenguGale</effecterDef>
      </li>
    </comps>
  </AbilityDef>
</Defs>