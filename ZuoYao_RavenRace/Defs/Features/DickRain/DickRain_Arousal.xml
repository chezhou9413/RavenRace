<Defs>
    <HediffDef>
        <defName>DickRain_Arousal</defName>
        <hediffClass>HediffWithComps</hediffClass>
        <label>性欲狂乱</label>
        <description>被迪克雨浸透的空气扰乱了这名小人的心智，强烈的欲望不断涌上心头。</description>
        <initialSeverity>0.0</initialSeverity>
        <maxSeverity>1.0</maxSeverity>
        <isBad>true</isBad>
        <alwaysShowSeverity>true</alwaysShowSeverity>

        <stages>
            <li>
                <!-- 阶段0：轻微 (0.0 ~ 0.4) -->
                <label>轻微躁动</label>
                <minSeverity>0.0</minSeverity>
            </li>
            <li>
                <!-- 阶段1：中度 (0.4 ~ 0.7)，开始影响专注力 -->
                <label>欲望涌现</label>
                <minSeverity>0.4</minSeverity>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>-0.10</offset>
                    </li>
                </capMods>
            </li>
            <li>
                <!-- 阶段2：重度 (0.7 ~ 1.0)，触发精神崩溃 -->
                <label>狂乱失控</label>
                <minSeverity>0.7</minSeverity>
                <capMods>
                    <li>
                        <capacity>Consciousness</capacity>
                        <offset>-0.25</offset>
                    </li>
                </capMods>
            </li>
        </stages>

        <comps>
            <li Class="RavenRace.Features.DickRain.HediffCompProperties_TriggerMentalBreakAtMax">
                <triggerSeverity>0.99</triggerSeverity>
                <mentalStateDef>DickRain_LustState</mentalStateDef>
            </li>
        </comps>
    </HediffDef>
</Defs>
