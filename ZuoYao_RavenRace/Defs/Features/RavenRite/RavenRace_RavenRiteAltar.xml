<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef ParentName="BuildingBase">

    <defName>RavenRace_RavenRiteAltar</defName>
    <label>渡鸦祭坛</label>
    <description>渡鸦族人举行古老晋升仪式的祭坛。主持者率众人在此祈颂，为族中佼佼者加冕新位。</description>

    <altitudeLayer>Building</altitudeLayer>
    <passability>Standable</passability>
    <fillPercent>0.5</fillPercent>
    <selectable>true</selectable>
    <useHitPoints>true</useHitPoints>
    <rotatable>false</rotatable>

    <graphicData>
      <graphicClass>Graphic_Single</graphicClass>
      <texPath>Buildings/RavenRiteAltar/RavenRiteAltar</texPath>
      <drawSize>(7,7)</drawSize>
      <shadowData>
        <volume>(0.8, 1, 0.8)</volume>
      </shadowData>
    </graphicData>

    <size>(5,5)</size>

    <!-- 移除 stuffCategories / costStuffCount / defaultStuff，改用固定材料 -->
    <costList>
      <BlocksGranite>75</BlocksGranite>
    </costList>

    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <WorkToBuild>8000</WorkToBuild>
      <Beauty>12</Beauty>
    </statBases>

    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>

    <ritualFocus>
      <spectateDistance>3</spectateDistance>
      <allowedSpectateSides>Down</allowedSpectateSides>
    </ritualFocus>

    <hasInteractionCell>true</hasInteractionCell>
    <interactionCellOffset>(0,0,-1)</interactionCellOffset>

    <building>
      <buildingTags>
        <li>RitualFocus</li>
      </buildingTags>
      <paintable>true</paintable>
    </building>

    <designationCategory>Raven_Category</designationCategory>
    <uiOrder>2015</uiOrder>

    <comps>
      <li Class="CompProperties_Styleable" />
      <li Class="RavenRace.Features.RavenRite.CustomRiteCore.Comp.CompProperties_RavenRite">
        <ritualLabel>渡鸦晋升仪式</ritualLabel>
        <gizmoDesc>在渡鸦祭坛前举行晋升仪式，指定主持者与参与者。</gizmoDesc>
        <cooldownDays>3</cooldownDays>
        <ritualWorkerClass>RavenRace.Features.RavenRite.CustomRiteCore.RiteWoker.TestRiteWorker</ritualWorkerClass>
        <roles>
          <li>
            <RoleId>host</RoleId>
            <Label>晋升者</Label>
            <MaxCount>1</MaxCount>
            <Required>true</Required>
            <filterClass>RavenRace.Features.RavenRite.CustomRiteCore.RaveFilter.RitualRoleFilter_ReadyForBreakthrough</filterClass>
          </li>
        </roles>
      </li>
    </comps>

  </ThingDef>
</Defs>