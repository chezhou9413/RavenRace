<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="ResourceBase">
    <defName>RavenItem_AbilityTome</defName>
    <label>渡鸦本能教本</label>
    <description>一本沾满干涸黏液的禁忌典籍。里面以极度露骨的插图和文字，记载了渡鸦族如何开发自身深不见底的肉体幽谷。通过学习，可以掌握利用极致的快感操控他人的“强制求爱”，以及将活人强行吞入阴道或直肠深处的恐怖技能——“吸星大法”。\n\n“成为我子宫里的一滩温热的肉泥吧……” —— 某位不愿透露姓名的司命</description>
    <graphicData>
      <texPath>Items/Misc/AbilityTome/AbilityTome</texPath> <!-- 复用贴图 -->
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <statBases>
      <MarketValue>750</MarketValue>
      <Mass>0.5</Mass>
    </statBases>
    <techLevel>Industrial</techLevel>
    <thingCategories>
      <li>Items</li>
    </thingCategories>
    <tradeTags>
      <li>ExoticMisc</li>
    </tradeTags>
    <comps>
      <li Class="CompProperties_Usable">
        <useJob>UseItem</useJob>
        <useLabel>学习渡鸦本能</useLabel>
        <useDuration>60</useDuration>
      </li>
      <li Class="CompProperties_Targetable">
        <compClass>CompTargetable_SinglePawn</compClass>
      </li>
      <!-- 使用重构后的多技能赋予组件 -->
      <li Class="RavenRace.Items.Comps.CompProperties_GainAbilities">
        <abilityDefs>
          <li>Raven_Ability_ForceLovin</li>
          <li>Raven_Ability_DevourPawn</li>
        </abilityDefs>
      </li>
      <li Class="CompProperties_UseEffectDestroySelf" />
    </comps>
  </ThingDef>

  <RecipeDef>
    <defName>Make_RavenItem_AbilityTome</defName>
    <label>抄写渡鸦本能教本</label>
    <description>抄写一本关于渡鸦族淫靡本能的教本。</description>
    <jobString>正在抄写教本。</jobString>
    <workAmount>50</workAmount>
    <workSpeedStat>ResearchSpeed</workSpeedStat>
    <effectWorking>Cook</effectWorking>
    <soundWorking>Recipe_CookMeal</soundWorking>
    <recipeUsers>
        <li>DrugLab</li>
    </recipeUsers>
    <researchPrerequisite>RavenResearch_Reproduction</researchPrerequisite>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </filter>
        <count>40</count>
      </li>
    </ingredients>
    <products>
      <RavenItem_AbilityTome>1</RavenItem_AbilityTome>
    </products>
  </RecipeDef>
</Defs>