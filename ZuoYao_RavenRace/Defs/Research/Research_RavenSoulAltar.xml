<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- 【四大基础之二：繁殖】 (无前置，400点) -->
  <ResearchProjectDef>
    <defName>RavenResearch_Reproduction</defName>
    <label>渡鸦繁殖基础</label>
    <description>解锁控制渡鸦族独特生殖周期的技术。</description>
    <baseCost>400</baseCost>
    <techLevel>Industrial</techLevel>
    <!-- 第一列，行2 -->
    <researchViewX>0.00</researchViewX>
    <researchViewY>3.50</researchViewY>
    <tab>Raven_ResearchTab</tab>
  </ResearchProjectDef>

  <!-- 【依附于繁殖：摇篮】 -->
  <ResearchProjectDef>
    <defName>RavenResearch_Cradle</defName>
    <label>渡鸦原始摇篮</label>
    <description>解锁制作原始摇篮，这是孵化渡鸦灵卵的基础设施。</description>
    <baseCost>400</baseCost>
    <techLevel>Neolithic</techLevel>
    <prerequisites>
      <li>RavenResearch_Reproduction</li>
    </prerequisites>
    <!-- 第二列，平移 -->
    <researchViewX>1.50</researchViewX>
    <researchViewY>3.50</researchViewY>
    <tab>Raven_ResearchTab</tab>
  </ResearchProjectDef>

  <ResearchProjectDef>
    <defName>RavenResearch_Altar_Core</defName>
    <label>远古孵化仪式</label>
    <description>研究如何建造扶桑育生祭坛的核心摇篮。</description>
    <baseCost>1200</baseCost>
    <techLevel>Industrial</techLevel>
    <prerequisites>
      <li>RavenResearch_Cradle</li>
      <li>Electricity</li>
    </prerequisites>
    <!-- 第三列，平移 -->
    <researchViewX>3.00</researchViewX>
    <researchViewY>3.50</researchViewY>
    <tab>Raven_ResearchTab</tab>
  </ResearchProjectDef>

  <ResearchProjectDef>
    <defName>RavenResearch_Altar_Infusion</defName>
    <label>外物注灵术</label>
    <description>解锁注灵器基座。</description>
    <baseCost>1500</baseCost>
    <techLevel>Industrial</techLevel>
    <prerequisites>
      <li>RavenResearch_Altar_Core</li>
    </prerequisites>
    <!-- 第四列，上扬 -->
    <researchViewX>4.50</researchViewX>
    <researchViewY>3.00</researchViewY>
    <tab>Raven_ResearchTab</tab>
  </ResearchProjectDef>

  <ResearchProjectDef>
    <defName>RavenResearch_Altar_Resonance</defName>
    <label>辉光共振原理</label>
    <description>解锁辉光共鸣桩。</description>
    <baseCost>1800</baseCost>
    <techLevel>Industrial</techLevel>
    <prerequisites>
      <li>RavenResearch_Altar_Core</li>
    </prerequisites>
    <!-- 第四列，下沉 -->
    <researchViewX>4.50</researchViewX>
    <researchViewY>4.00</researchViewY>
    <tab>Raven_ResearchTab</tab>
  </ResearchProjectDef>

  <ResearchProjectDef>
    <defName>RavenResearch_Altar_Transformation</defName>
    <label>血脉精炼</label>
    <description>解锁蜕凡注入仪。</description>
    <baseCost>2500</baseCost>
    <techLevel>Spacer</techLevel>
    <prerequisites>
      <li>RavenResearch_Altar_Infusion</li>
      <li>RavenResearch_Altar_Resonance</li>
    </prerequisites>
    <!-- 第五列，汇聚回中 -->
    <researchViewX>6.00</researchViewX>
    <researchViewY>3.50</researchViewY>
    <tab>Raven_ResearchTab</tab>
  </ResearchProjectDef>

</Defs>